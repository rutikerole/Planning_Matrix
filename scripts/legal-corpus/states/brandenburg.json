      "heading_de_official": "Vorrang anderer Gestattungsverfahren",
      "heading_source_url": "https://www.baunormenlexikon.de/norm/bbgbo/9e43e85a-7c8d-4041-b0bd-4b91f839545f",
      "heading_fetched_at": "2026-05-27",
