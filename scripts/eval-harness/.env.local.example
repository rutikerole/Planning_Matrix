# Phase 7 — eval harness local secrets template.
#
# Copy to .env.local at the repo root (NOT inside scripts/eval-harness/),
# fill in real values, and confirm .env.local is gitignored.
#
# .env.local is loaded by scripts/eval-harness/lib/config.mjs only — the
# Vite SPA reads its own VITE_-prefixed vars from the same file.

# Production Supabase project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key. POWERFUL — keep out of logs, screenshots, screen
# shares, and chat. Used only for Auth admin operations + the apikey
# header on REST + Edge Function calls.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace_me

# Fixed strong password for the test user. Generate once via:
#   openssl rand -hex 24
# Rotate by deleting the test user via service-role and re-creating
# with a new password.
EVAL_HARNESS_TEST_USER_PASSWORD=replace_me_with_a_24_byte_hex_string
