# ───────────────────────────────────────────────────────────────────────
# Supabase project credentials.
#
# Dashboard → Project Settings → API → URL + anon public key.
# Both must be set as Vercel env vars (Production + Preview) for the
# deployed app to authenticate.
# ───────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-public-key

# ───────────────────────────────────────────────────────────────────────
# Telemetry (consent-gated; SDKs only initialise when consent + PROD).
# ───────────────────────────────────────────────────────────────────────

VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=

# ───────────────────────────────────────────────────────────────────────
# Legal-page provider details (v1.0.4).
#
# Required by § 5 DDG / § 18 Abs. 2 MStV. The build-time validator
# (scripts/verify-legal-config.mjs, wired into `npm run prebuild`)
# fails the build if any of these is unset OR still wrapped in
# `{{...}}`. The runtime falls back to a "Provider details unavailable"
# banner instead of leaking literal placeholder syntax to the visitor.
#
# Fill these with REAL values for any deploy that serves public traffic.
# Local-dev placeholder values are accepted by the validator (any
# non-empty, non-`{{...}}` string passes) but DO NOT ship those to
# production — § 5 DDG mandates real, contactable details.
# ───────────────────────────────────────────────────────────────────────

VITE_LEGAL_ANBIETER_NAME=Mustermann GmbH
VITE_LEGAL_ANBIETER_STRASSE_HAUSNUMMER=Musterstraße 1
VITE_LEGAL_ANBIETER_PLZ=80331
VITE_LEGAL_ANBIETER_ORT=München
VITE_LEGAL_KONTAKT_TELEFON=+49 89 1234567
VITE_LEGAL_KONTAKT_EMAIL=kontakt@example.com
VITE_LEGAL_UST_ID_HINWEIS=nicht zutreffend
VITE_LEGAL_HANDELSREGISTER_HINWEIS=nicht eingetragen
