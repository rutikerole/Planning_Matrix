# Supabase project credentials.
#
# Get these from your Supabase project's API settings:
#   Dashboard → Project Settings → API
#   Or: https://supabase.com/dashboard/project/_/settings/api
#
# See SUPABASE_SETUP.md for full setup instructions.
#
# Copy this file to .env.local and fill in real values for local
# development. Both VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY must
# also be set as Vercel environment variables (Production + Preview)
# for the deployed app to authenticate.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-public-key
