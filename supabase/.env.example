# Edge Function secrets — Phase 3 chat-turn.
#
# Production:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   (Set once. SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
#    are auto-injected by the platform — do NOT set them manually.)
#
# Local dev:
#   cp supabase/.env.example supabase/.env.local
#   # fill in real values, then:
#   supabase functions serve chat-turn --env-file ./supabase/.env.local
#
# .env.local is gitignored at the repo root via the existing .env.local
# pattern; this file is the only one that should ever be committed.

ANTHROPIC_API_KEY=sk-ant-your-key-here
