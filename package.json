{
  "name": "planning-matrix",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "verify:locales": "node scripts/verify-locale-parity.mjs",
    "verify:hardcoded-de": "node scripts/grep-hardcoded-de.mjs",
    "verify:bundle": "node scripts/verify-bundle-size.mjs",
    "verify:legal-config": "node scripts/verify-legal-config.mjs",
    "prebuild": "npm run verify:locales && npm run verify:hardcoded-de && npm run verify:legal-config",
    "build": "tsc -b && vite build && npm run verify:bundle",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "images": "node scripts/process-images.mjs",
    "images:download": "bash scripts/download-images.sh",
    "freshness:check": "node scripts/freshness-check.mjs",
    "freshness:report": "node scripts/freshness-check.mjs --report-only",
    "smoke:citations": "node scripts/smokeWalk.mjs",
    "smoke:citations:live": "node scripts/smokeWalk.mjs --live",
    "smoke:pdf-text": "npx tsx scripts/smoke-pdf-text.mts",
    "smoke:architect-e2e": "node scripts/architect-e2e-smoke.mjs",
    "smoke:matrix": "node scripts/smoke-walk-matrix.mjs",
    "verify:bayern-sha": "node scripts/verify-bayern-sha.mjs",
    "eval:run": "node scripts/eval-harness/run.mjs",
    "eval:dry-run": "node scripts/eval-harness/run.mjs --dry-run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/react": "^9.47.1",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.100.5",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.23",
    "lucide-react": "^1.11.0",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.372.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^17.0.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
